{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build opencv",
            "type": "shell",
            "command": "g++",
            "args": [
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-std=c++17",
                "`pkg-config",
                "--cflags",
                "--libs",
                "opencv4`"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
